// Prisma schema — Solar ROI Egypt
// Database: PostgreSQL (Neon, Supabase, or any Postgres provider)
// Local dev: set DATABASE_URL in .env to your Postgres connection string
// Vercel: set DATABASE_URL in project environment variables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon (and some other providers) require a non-pooling URL for migrations.
  // If you use Neon, also set DIRECT_URL in your env:
  //   directUrl = env("DIRECT_URL")
  // and uncomment the line above. For a basic Neon setup the pooled URL works fine.
}

model Epc {
  id           Int       @id @default(autoincrement())
  name         String
  email        String
  logoUrl      String?
  brandColor   String    @default("#0d6e74")
  discountRate Float     @default(0.11)
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id                 Int      @id @default(autoincrement())
  epcId              Int
  epc                Epc      @relation(fields: [epcId], references: [id])

  // Client info
  clientName         String
  siteName           String
  city               String

  // System design
  systemSizeKwp      Float
  capexPerKwp        Float
  oAndMPercent       Float    @default(1.0)

  // Production
  region             String
  specificYield      Float

  // Tariffs
  tariffType         String
  tariffValue        Float
  escalationScenario String

  // Financing
  financingMode      String   @default("cash")
  financingParams    String?  // JSON string: { loanShare, interestRate, tenorYears }

  // Analysis
  analysisPeriod     Int      @default(25)

  // Computed results (stored for fast retrieval)
  simplePayback      Float?
  npv                Float?
  irr                Float?
  annualProduction   Float?

  createdAt          DateTime @default(now())
}
