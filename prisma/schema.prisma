// Prisma schema — Solar ROI Egypt  (V3)
// Database: PostgreSQL (Neon, Supabase, or any Postgres provider)

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Epc {
  id           Int       @id @default(autoincrement())
  name         String
  email        String
  phone        String?
  logoUrl      String?
  brandColor   String    @default("#0d6e74")
  discountRate Float     @default(0.11)
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id                 Int      @id @default(autoincrement())
  epcId              Int
  epc                Epc      @relation(fields: [epcId], references: [id])

  // ── Project metadata (V3) ──────────────────────────────────────────────
  projectName        String?         // e.g. "Solar ROI Study – Cairo Textile"
  siteAddress        String?         // full address
  gpsCoords          String?         // optional "30.0626° N, 31.2497° E"
  projectNote        String?         // short EPC rationale / sales note

  // ── Client info ────────────────────────────────────────────────────────
  clientName         String
  siteName           String
  city               String

  // ── System design ──────────────────────────────────────────────────────
  systemSizeKwp      Float
  capexPerKwp        Float
  oAndMPercent       Float    @default(1.0)

  // ── Optional technical BOM (V3) ────────────────────────────────────────
  moduleModel        String?         // e.g. "JA Solar JAM72S30 550W"
  inverterModel      String?         // e.g. "Huawei SUN2000-215KTL"
  storageModel       String?         // e.g. "CATL EnerOne"
  storageCapacityKwh Float?          // kWh

  // ── Production ─────────────────────────────────────────────────────────
  region             String
  specificYield      Float

  // ── Tariffs ────────────────────────────────────────────────────────────
  tariffType         String
  tariffValue        Float
  exportTariff       Float           @default(0.0)
  escalationScenario String

  // ── Self-consumption ───────────────────────────────────────────────────
  consumptionKwh     Float?
  selfConsumptionRatio Float         @default(0.8)

  // ── Financing ──────────────────────────────────────────────────────────
  financingMode      String   @default("cash")
  financingParams    String?

  // ── Analysis ───────────────────────────────────────────────────────────
  analysisPeriod     Int      @default(25)

  // ── Computed results ───────────────────────────────────────────────────
  simplePayback      Float?
  npv                Float?
  irr                Float?
  annualProduction   Float?

  createdAt          DateTime @default(now())
}
