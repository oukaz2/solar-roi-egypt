// Prisma schema — Solar ROI Egypt
// Database: PostgreSQL (Neon, Supabase, or any Postgres provider)

generator client {
  provider      = "prisma-client-js"
  // Generate the client into a path that Vercel never caches between builds.
  // This guarantees the correct query engine (libquery_engine-*.so.node) is
  // always freshly generated for the current provider on every deploy.
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Epc {
  id           Int       @id @default(autoincrement())
  name         String
  email        String
  logoUrl      String?
  brandColor   String    @default("#0d6e74")
  discountRate Float     @default(0.11)
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id                 Int      @id @default(autoincrement())
  epcId              Int
  epc                Epc      @relation(fields: [epcId], references: [id])

  // Client info
  clientName         String
  siteName           String
  city               String

  // System design
  systemSizeKwp      Float
  capexPerKwp        Float
  oAndMPercent       Float    @default(1.0)

  // Production
  region             String
  specificYield      Float

  // Tariffs
  tariffType         String
  tariffValue        Float
  escalationScenario String

  // Financing
  financingMode      String   @default("cash")
  financingParams    String?  // JSON string: { loanShare, interestRate, tenorYears }

  // Analysis
  analysisPeriod     Int      @default(25)

  // Computed results (stored for fast retrieval)
  simplePayback      Float?
  npv                Float?
  irr                Float?
  annualProduction   Float?

  createdAt          DateTime @default(now())
}
